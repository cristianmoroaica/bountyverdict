      "name": "SkillVerdict",
      "method": "GET",
      "path": "/api/skill",
      "price_usdc": "0.06",
      "reusable": true,
      "use_when": "Audit a public SKILL.md bundle before loading, installing, or executing it.",
      "skill_url": "https://cristianmoroaica.github.io/bountyverdict/skills/preflight-agent-skills/SKILL.md",
      "install_command": "npx skills add cristianmoroaica/bountyverdict --skill preflight-agent-skills -y",
