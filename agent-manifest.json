    {
      "name": "BountyVerdict Portfolio",
      "method": "POST",
      "path": "/api/portfolio",
      "price_usdc": "0.40",
      "reusable": true,
      "use_when": "Rank two to ten public GitHub bounty candidates with partial-failure handling.",
      "skill_url": "https://cristianmoroaica.github.io/bountyverdict/skills/preflight-github-bounties/SKILL.md",
      "install_command": "npx skills add cristianmoroaica/bountyverdict --skill preflight-github-bounties -y",
