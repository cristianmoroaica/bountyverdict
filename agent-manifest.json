      "maximum_candidates": 10,
      "sample": "https://cristianmoroaica.github.io/bountyverdict/samples/portfolio.json"
    },
    {
      "name": "HarnessVerdict",
      "method": "GET",
      "path": "/api/harness",
      "price_usdc": "0.03",
      "reusable": true,
