{
  "name": "bountyverdict-agent-api",
  "version": "1.1.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:dry": "wrangler deploy --dry-run --env=''",
    "payment:inspect": "node --env-file-if-exists=.dev.vars --experimental-strip-types scripts/payment-smoke.ts",
    "payment:smoke": "EXECUTE_PAYMENT=YES node --env-file-if-exists=.dev.vars --experimental-strip-types scripts/payment-smoke.ts",
    "wallet:test": "node --env-file-if-exists=.dev.vars --experimental-strip-types scripts/cdp-test-wallet.ts",
    "wallet:fund": "REQUEST_FUNDS=YES node --env-file-if-exists=.dev.vars --experimental-strip-types scripts/cdp-test-wallet.ts",
    "revenue": "node --env-file-if-exists=.dev.vars --experimental-strip-types scripts/revenue-monitor.ts",
    "distribution:monitor": "node --experimental-strip-types scripts/distribution-monitor.ts",
    "funnel:tail": "node --env-file-if-exists=.dev.vars --experimental-strip-types scripts/cloudflare-funnel-tail.ts",
    "funnel:epoch": "node --experimental-strip-types scripts/start-funnel-epoch.ts",
    "monitor:audited": "node --experimental-strip-types scripts/run-audited-monitor.ts",
    "the402:onboard": "node --experimental-strip-types scripts/the402-onboard.ts",
    "the402:plan": "node --experimental-strip-types scripts/the402-plan.ts",
    "the402:subscribe": "node --experimental-strip-types scripts/the402-subscribe.ts",
    "near-market:register": "node --experimental-strip-types scripts/near-market-register.ts",
    "near-market:onboard": "node --experimental-strip-types scripts/near-market-onboard.ts",
    "payan:register": "node --experimental-strip-types scripts/payan-register.ts",
    "payan:onboard": "node --experimental-strip-types scripts/payan-onboard.ts",
    "payan:demand": "node --experimental-strip-types scripts/payan-demand.ts",
    "demand:watch": "node --experimental-strip-types scripts/demand-watch.ts",
    "taskmarket:aibtc-submit": "node --experimental-strip-types scripts/taskmarket-aibtc-submit.ts",
    "clawlancer:work": "node --experimental-strip-types scripts/clawlancer-work.ts",
    "the402:register": "node --env-file-if-exists=.dev.vars --experimental-strip-types scripts/the402-register.ts",
    "canary:production": "node --experimental-strip-types scripts/functional-canary.ts",
    "settlement:provision": "node --env-file-if-exists=.dev.vars --experimental-strip-types scripts/provision-settlement-buyer.ts",
    "settlement:canary": "node --env-file-if-exists=.dev.vars --experimental-strip-types scripts/settlement-canary.ts",
    "manifest:activate": "node --experimental-strip-types scripts/activate-manifest.ts",
    "glama:verify": "node --experimental-strip-types scripts/verify-glama-release.ts",
    "test": "node --experimental-strip-types --test tests/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@coinbase/cdp-sdk": "1.54.0",
    "@coinbase/x402": "2.1.0",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@x402/core": "2.19.0",
    "@x402/evm": "2.19.0",
    "@x402/extensions": "2.19.0",
    "@x402/fetch": "2.19.0",
    "@x402/hono": "2.19.0",
    "@x402/mcp": "2.19.0",
    "@x402/svm": "2.19.0",
    "hono": "4.12.31",
    "viem": "2.55.4",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "5.20260721.1",
    "@types/node": "26.1.1",
    "node-addon-api": "8.9.0",
    "node-gyp": "13.0.1",
    "typescript": "7.0.2",
    "wrangler": "4.112.0"
  },
  "optionalDependencies": {
    "@img/sharp-libvips-linux-x64": "1.3.2",
    "@img/sharp-linux-x64": "0.35.3"
  },
  "overrides": {
    "@hono/node-server": "2.0.11",
    "axios": "1.18.1"
  }
}
