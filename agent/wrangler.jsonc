{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "bountyverdict-agent",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-20",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "vars": {
    "X402_NETWORK": "eip155:84532",
    "X402_FACILITATOR_URL": "https://x402.org/facilitator"
  },
  "ratelimits": [
    {
      "name": "CANARY_RATE_LIMITER",
      "namespace_id": "402701",
      "simple": { "limit": 1, "period": 60 }
    },
    {
      "name": "FLAKE_RATE_LIMITER",
      "namespace_id": "402703",
      "simple": { "limit": 10, "period": 60 }
    }
  ],
  "env": {
    "production": {
      "name": "bountyverdict-agent-production",
      "vars": {
        "X402_NETWORK": "eip155:8453",
        "X402_FACILITATOR_URL": "https://api.cdp.coinbase.com/platform/v2/x402",
        "THE402_SERVICE_MAP": "{\"svc_5e36dabc8b434e95\":\"single\",\"svc_780bf04bd8204b2f\":\"portfolio\",\"svc_df4baf282b7d48d5\":\"harness\",\"svc_cdd16073d02c4429\":\"run\",\"svc_565a2a5c8e154b6e\":\"flake\",\"svc_40e97a390c5b4d71\":\"mcpdrift\"}"
      },
      "ratelimits": [
        {
          "name": "CANARY_RATE_LIMITER",
          "namespace_id": "402702",
          "simple": { "limit": 1, "period": 60 }
        },
        {
          "name": "FLAKE_RATE_LIMITER",
          "namespace_id": "402704",
          "simple": { "limit": 10, "period": 60 }
        }
      ]
    }
  }
}
